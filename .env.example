# Copy to .env and `set -a; . ./.env; set +a` (or let start.sh source it).
# NEVER put a real key in this file — it's a committed template. Put real keys
# in .env (gitignored).

# --- LLM provider --------------------------------------------------------
# Auto-detected from whichever key is set if CTF_PROVIDER is unset.
# CTF_PROVIDER=anthropic            # anthropic | openai

# Provide the key for whichever provider(s) you use (chat needs at least one):
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# Point the OpenAI provider at any OpenAI-compatible endpoint to reach other
# models (OpenRouter -> Gemini/Llama/Mistral/..., Groq, Together, Ollama, vLLM):
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Model / generation --------------------------------------------------
# CTF_MODEL=                        # default: claude-opus-4-8 (anthropic) / gpt-4o (openai)
# CTF_EFFORT=high                   # anthropic only: high | medium | low
# CTF_MAX_OUTPUT_TOKENS=4096

# --- Aggregator / context ------------------------------------------------
# CTF_HOST=127.0.0.1
# CTF_PORT=7331
# CTF_CONTEXT_TOKENS=6000           # budget for injected live context
# CTF_POLL_INTERVAL=2.0             # tmux poll cadence (seconds)
# CTF_STALE_AFTER=120               # drop browser/app data older than this (seconds)
# CTF_SCREENSHOT_FLAG=/tmp/ctf_screenshot_requested

# --- Vuln intel + LLM parsing --------------------------------------------
# NVD_API_KEY=                     # optional, raises NVD rate limit
# CTF_VULN_LOOKUP=1                # auto version->CVE lookups (0 to disable)
# CTF_AUTO_PARSE=1                 # auto LLM-parse stabilized tmux output (0 to disable)
# CTF_PARSE_STABLE_SECONDS=6       # how long a pane must be unchanged before auto-parse
# CTF_SESSION=default              # engagement/session name
# CTF_DATA_DIR=~/.ctf-brain/engagements
