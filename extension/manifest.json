{
  "manifest_version": 3,
  "name": "CTF-Brain Collector",
  "version": "0.1.0",
  "description": "Streams the active page's context (URL, selection, visible text, requests) to the local ctf-brain aggregator.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:7331/*",
    "http://127.0.0.1:7331/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_title": "CTF-Brain Collector"
  }
}
